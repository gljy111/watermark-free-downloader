<view class="container" wx:if="{{result}}">
  <!-- 视频/图片预览 -->
  <view class="card preview-card">
    <!-- 视频封面 -->
    <view class="cover-wrap" wx:if="{{result.type === 'video'}}">
      <image class="cover" src="{{result.cover}}" mode="aspectFill" />
      <view class="play-icon">▶</view>
    </view>

    <!-- 图集预览 -->
    <view class="image-grid" wx:if="{{result.type === 'images'}}">
      <image
        wx:for="{{result.images}}"
        wx:key="*this"
        class="grid-image"
        src="{{item}}"
        mode="aspectFill"
        data-url="{{item}}"
        bindtap="onPreviewImage"
      />
    </view>

    <!-- 信息 -->
    <view class="info">
      <text class="info-title">{{result.title || '无标题'}}</text>
      <view class="info-meta">
        <text class="info-author" wx:if="{{result.author}}">@{{result.author}}</text>
        <text class="info-platform">{{result.platformLabel}}</text>
      </view>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="actions">
    <!-- 视频保存 -->
    <button
      wx:if="{{result.type === 'video'}}"
      class="btn-primary btn-save"
      bindtap="onSaveVideo"
      loading="{{saving}}"
    >
      {{saving ? '保存中...' : '保存视频到相册'}}
    </button>

    <!-- 图片保存 -->
    <button
      wx:if="{{result.type === 'images'}}"
      class="btn-primary btn-save"
      bindtap="onSaveImages"
      loading="{{saving}}"
    >
      {{saving ? '保存中...' : '保存全部图片 (' + result.images.length + '张)'}}
    </button>

    <!-- 复制链接 -->
    <button class="btn-secondary" bindtap="onCopyLink">复制下载链接</button>
  </view>

  <!-- 广告 -->
  <ad unit-id="adunit-placeholder" ad-type="banner" ad-theme="white" style="margin-top: 40rpx;"></ad>
</view>
