.preview-card {
  overflow: hidden;
  padding: 0;
}

.cover-wrap {
  position: relative;
  width: 100%;
  height: 400rpx;
}

.cover {
  width: 100%;
  height: 100%;
}

.play-icon {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 80rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background-color: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
  color: #ffffff;
  font-size: 32rpx;
}

.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 4rpx;
}

.grid-image {
  width: calc(33.33% - 3rpx);
  height: 220rpx;
}

.info {
  padding: 24rpx 30rpx;
}

.info-title {
  display: block;
  font-size: 30rpx;
  font-weight: 500;
  color: #1a1a1a;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.info-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 12rpx;
}

.info-author {
  font-size: 24rpx;
  color: #666666;
}

.info-platform {
  font-size: 22rpx;
  color: #07c160;
  background-color: rgba(7, 193, 96, 0.08);
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

.actions {
  margin-top: 30rpx;
}

.btn-save {
  margin-bottom: 20rpx;
}

.btn-secondary {
  background-color: #ffffff;
  color: #07c160;
  border: 2rpx solid #07c160;
  border-radius: 12rpx;
  font-size: 30rpx;
  height: 84rpx;
  line-height: 84rpx;
}

.btn-secondary::after {
  border: none;
}
