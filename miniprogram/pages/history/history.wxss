.top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.top-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.btn-clear-all {
  font-size: 26rpx;
  color: #ff4d4f;
}

.history-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx;
}

.item-cover {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.item-info {
  flex: 1;
  overflow: hidden;
}

.item-title {
  display: block;
  font-size: 28rpx;
  color: #333333;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.item-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 10rpx;
}

.item-platform {
  font-size: 22rpx;
  color: #07c160;
  background-color: rgba(7, 193, 96, 0.08);
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
}

.item-type {
  font-size: 22rpx;
  color: #999999;
}

.empty {
  text-align: center;
  padding: 200rpx 0;
}

.empty-text {
  display: block;
  font-size: 32rpx;
  color: #999999;
}

.empty-hint {
  display: block;
  font-size: 26rpx;
  color: #cccccc;
  margin-top: 12rpx;
}

.loading-more {
  text-align: center;
  padding: 30rpx;
  font-size: 24rpx;
  color: #999999;
}
