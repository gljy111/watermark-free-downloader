<view class="container">
  <view class="header">
    <text class="app-name">无水印下载</text>
    <text class="app-version">v{{version}}</text>
  </view>

  <view class="menu-group">
    <view class="card menu-card">
      <button class="menu-item" open-type="share">
        <text class="menu-label">分享给朋友</text>
        <text class="menu-arrow">›</text>
      </button>
      <view class="menu-divider"></view>
      <button class="menu-item" open-type="feedback">
        <text class="menu-label">意见反馈</text>
        <text class="menu-arrow">›</text>
      </button>
      <view class="menu-divider"></view>
      <view class="menu-item" bindtap="onAbout">
        <text class="menu-label">关于</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 广告 -->
  <ad unit-id="adunit-placeholder" ad-type="banner" ad-theme="white" style="margin-top: 40rpx;"></ad>
</view>
